              <AuxValues>
                <AuxValue name="JavaCodeGenerator_AddingCodePost" type="java.lang.String" value="jTable1.addMouseListener(new MouseAdapter() {&#xa;    public void mousePressed(MouseEvent mouseEvent) {&#xa;        JTable table =(JTable) mouseEvent.getSource();&#xa;        Point point = mouseEvent.getPoint();&#xa;        int row = table.rowAtPoint(point);&#xa;        if (mouseEvent.getClickCount() == 2 &amp;&amp; table.getSelectedRow() != -1) {&#xa;            &#xa;            String cuerpo = String.valueOf(main.java.modelo.getValueAt(row, 3));&#xa;            String archivo = String.valueOf(main.java.modelo.getValueAt(row, 4));&#xa;            String destinatario = String.valueOf(main.java.modelo.getValueAt(row, 2));&#xa;            String remitente = String.valueOf(main.java.modelo.getValueAt(row, 5));&#xa;            System.out.println(&quot;Cuerpo: &quot; + cuerpo);&#xa;            System.out.println(&quot;Archivo: &quot; + archivo);&#xa;            System.out.println(&quot;Destinatario: &quot; + destinatario);&#xa;            System.out.println(&quot;Remitente: &quot; + remitente);&#xa;            ventanaEmail vme = new ventanaEmail(parent, true, archivo, destinatario, remitente, cuerpo);&#xa;            vme.setVisible(true);&#xa;        }&#xa;    }&#xa;});&#xa;int anchos[] = {98, 352, 264};&#xa;        for (int i = 0; i &lt; 3; i++) {&#xa;            jTable1.getColumnModel().getColumn(i).setPreferredWidth(anchos[i]);&#xa;        }"/>
